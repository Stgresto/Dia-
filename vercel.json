{
  "functions": {
    "api/chat.js": {
      "maxDuration": 30
    },
    "api/dexcom.js": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/community", "destination": "/diastyle_community.html" },
    { "source": "/shop", "destination": "/diastyle_shop.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
